# Append these lines to .env for native dev (npm run dev + npm run livekit:run).
# Keys must match src/livekit/dev.yaml. Docker compose uses ws://livekit:8303 automatically.
LAN_IP=192.168.1.14
LIVEKIT_API_KEY=fromchat_dev
LIVEKIT_API_SECRET=local_dev_secret_must_be_at_least_32_characters_long
LIVEKIT_URL=ws://192.168.1.14:8303
